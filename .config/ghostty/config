theme = TokyoNight

shell-integration = zsh
shell-integration-features = ssh-terminfo,ssh-env,title,cursor,sudo

# macos
macos-titlebar-style = tabs

# Focus splits
keybind = super+k=goto_split:up
keybind = super+j=goto_split:down
keybind = super+h=goto_split:left
keybind = super+l=goto_split:right
 
# Toggle zoom on the current split (tmux's 'resize-pane -Z')
keybind = super+enter=toggle_split_zoom
